# Environment Configuration
# Copy this file to .env.{environment} and set appropriate values

# Application Environment
VITE_ENV=demo

# API Configuration
VITE_API_BASE=https://api.snaphomz.in

# Analytics
VITE_GA_TRACKING_ID=

# Domain Configuration (set per environment)
VITE_DOMAIN=snaphomz.in

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true
